/placeorder: 
  description: To get orders by state wise and if state not provided all
  get:
    headers:
        x-correlation-id:
          required: false
          type: string
          example: "7474774"
        x-transaction-id:
          required: false
          type: string
          example: "74a2d61f-a3cb-4b1b-9e97-767236ee0620" 
    queryParameters:
      state:
        required: false
        type: string
        example: "us"
    responses:
      200:
        body:
          application/json:
            type: array
            items:
              type: object
              properties:
                state:
                  type: string
                  example: "us"
                order:
                  type: object
                  properties:
                    total:
                      type: number
                      example: 46744
                    orderID:
                      type: number
                      example: 436744
                    totalNumbers:
                      type: number
                      example: 433744
                    Id's:
                      type: number
                      example: 300
                    members:
                      type: number
                      example: 7847848
            example:
              [
                    {
                        "state":"texas",
                        "order":{
                          "total":46744,
                          "orderID":436744,
                          "totalNumbers":433744,
                          "Id's":300,
                          "members":7847848
                        }
                    }
              ]
      503:
          body:
            application/json:
              type: object
              properties:
                code:
                  type: integer
                  example: 503
                  required: true 
                message:
                  example: Service unavailable
                  type: string
                  required: true
                description:
                  example: The (upstream) service is temporarily
                  type: string
                  required: false
                dateTime:
                  example: 2021-05-31T06:18:02Z
                  type: datetime
                  required: true
                transactionId:
                  example: 48n32920-69ne-47b4-907d-fa15869f3c4d
                  type: string
                  required: true
              example:
                    {
                      "code":503,
                      "message":"Service unavailable",
                      "description":"The (upstream) service is temporarily",
                      "dateTime":"2021-05-31T06:18:02Z",
                      "transactionId":"48n32920-69ne-47b4-907d-fa15869f3c4d"
                    }
      500:
          body:
            application/json:
              type: object
              properties:
                code:
                  type: integer
                  example: 500
                  required: true 
                message:
                  example: Internal server error
                  type: string
                  required: true
                description:
                  example: The server encountered an unexpected condition
                  type: string
                  required: false
                dateTime:
                  example: 2021-05-31T06:18:02Z
                  type: datetime
                  required: true
                transactionId:
                  example: 48n32920-69ne-47b4-907d-fa15869f3c4d
                  type: string
                  required: true
              example:
                    {
                      "code":500,
                      "message":"Internal server error",
                      "description":"The server encountered an unexpected",
                      "dateTime":"2021-05-31T06:18:02Z",
                      "transactionId":"48n32920-69ne-47b4-907d-fa15869f3c4d"
                    }
            
    

    