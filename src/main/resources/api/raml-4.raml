                      "transactionId":"48n32920-69ne-47b4-907d-fa15869f3c4d"
                    }
        500:
          body:
            application/json:
              type: object
              properties:
                code:
                  type: integer
                  example: 500
                  required: true 
                message:
                  example: Internal server error
                  type: string
